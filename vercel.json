{
  "buildCommand": "cd frontend-web && npm install && npm run build",
  "outputDirectory": "frontend-web/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 10,
      "runtime": "vercel-js@4.0.0"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/frontend-web/$1" }
  ]
}
